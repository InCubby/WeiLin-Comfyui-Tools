{
  "name": "weilin-comfyui-tools",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audit": "yarn audit --level moderate",
    "audit:fix": "yarn audit fix",
    "outdated": "yarn outdated",
    "upgrade": "yarn upgrade",
    "clean": "yarn cache clean",
    "lint": "eslint . --ext .vue,.js",
    "lint:fix": "eslint . --ext .vue,.js --fix",
    "format": "prettier --write \"**/*.{vue,js,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{vue,js,json,css,scss,md}\"",
    "quality": "yarn lint && yarn format:check",
    "quality:fix": "yarn lint:fix && yarn format",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "interactjs": "^1.10.27",
    "js-yaml": "^4.1.0",
    "pako": "^2.1.0",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "^4.2.0",
    "terser": "^5.37.0",
    "uuidv7": "^1.0.2",
    "vue": "^3.5.13",
    "vue-clipboard3": "^2.0.0",
    "vue-i18n": "^11.1.2",
    "vue3-json-viewer": "^2.3.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^8",
    "eslint-plugin-vue": "^9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vite": "^6.0.9"
  }
}
